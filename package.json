{
  "name": "template-vue",
  "version": "2.0.0",
  "type": "module",
  "description": "Vue 3 + TypeScript 团队开发模板",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "setup": "npm install && npm run prepare",
    "prepare": "husky && git config core.hooksPath .husky",
    "install:ext": "bash scripts/install-extensions.sh"
  },
  "engines": {
    "node": "20.19.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "naive-ui": "^2.40.0",
    "pinia": "^2.1.0",
    "tailwindcss": "^4.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.0.0",
    "@pinia/testing": "^0.1.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-boundaries": "^7.0.0-beta.2",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^15.0.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "unplugin-auto-import": "^0.18.0",
    "unplugin-vue-components": "^0.27.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^2.0.0"
  }
}
