{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.*?):(\\d+):(\\d+):\\s+(error|warning)\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE\\s+ready.*$",
          "endsPattern": "^.*VITE\\s+error.*$"
        }
      }
    },
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "problemMatcher": []
    },
    {
      "label": "npm: lint",
      "type": "npm",
      "script": "lint",
      "problemMatcher": []
    },
    {
      "label": "npm: type-check",
      "type": "npm",
      "script": "type-check",
      "problemMatcher": []
    }
  ]
}
